# ─────────────────────────────────────
# SERVER
# ─────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─────────────────────────────────────
# POSTGRESQL
# ─────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/coding_tracker

# ─────────────────────────────────────
# REDIS
# ─────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────
# JWT
# ─────────────────────────────────────
JWT_SECRET=replace_this_with_a_very_long_random_secret_key
# Short token TTL in seconds (5 minutes)
JWT_SHORT_TTL=300
# Refresh token TTL in seconds (3 days)
JWT_REFRESH_TTL=259200

# ─────────────────────────────────────
# EMAIL / SMTP  (Gmail example)
# ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
FROM_EMAIL=noreply@acet.ac.in

# ─────────────────────────────────────
# COLLEGE CONFIGURATION
# ─────────────────────────────────────
# Comma-separated list of ALL allowed college email domains
COLLEGE_EMAIL_DOMAINS=@acet.ac.in,@aec.edu.in,@adityauniversity.in
# College student DB REST API (set your college API URL here)
COLLEGE_DB_API_URL=https://your-college-api.example.com/api/students
COLLEGE_DB_API_KEY=your_college_api_key

# ─────────────────────────────────────
# ADMIN
# ─────────────────────────────────────
# Send this as  X-Admin-Secret  header on admin routes
ADMIN_SECRET=replace_with_a_secure_admin_secret

# ─────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────
# 15-minute window, 100 requests per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
