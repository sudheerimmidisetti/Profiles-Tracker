# ============================================================
# CPTrack — PRODUCTION .env for EC2
# Deploy at: api.dealance.app
# ============================================================

NODE_ENV=production
PORT=3000

# ── PostgreSQL (local on EC2) ────────────────────────────────
DATABASE_URL=postgresql://cptrack:CHANGE_THIS_PASSWORD@localhost:5432/coding_tracker

# ── Redis (local on EC2) ────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ─────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_96_CHAR_RANDOM_HEX
JWT_SHORT_TTL=300
JWT_REFRESH_TTL=604800

# ── AWS SES SMTP (Mumbai region) ────────────────────────────
# After verifying dealance.app domain in SES console:
SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=REPLACE_WITH_SES_SMTP_USERNAME
SMTP_PASS=REPLACE_WITH_SES_SMTP_PASSWORD
FROM_EMAIL=noreply@dealance.app

# ── College Config ───────────────────────────────────────────
COLLEGE_EMAIL_DOMAINS=@acet.ac.in,@aec.edu.in,@adityauniversity.in
# Maya student API (Aditya University ERP). Override if URL changes.
MAYA_API_URL=https://api.maya.adityauniversity.in/node/api/get-user-by-roll-no-coding-profiles
# Human-readable college labels for each email domain (comma-separated key=value pairs)
COLLEGE_LABEL_MAP=acet.ac.in=ACET,aec.edu.in=AEC,adityauniversity.in=Aditya University

# ── CORS — only your two frontends ──────────────────────────
CORS_ORIGIN=https://tracker.dealance.app,https://admin.dealance.app

# ── Admin ────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
